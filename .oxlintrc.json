{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "categories": { "correctness": "error" },
  "env": { "es2024": true },
  "rules": {
    // Pre-sized typed buffers are this codebase's deliberate flat-array idiom
    // (integer-only sim grids, resource strides): `new Array(n)` is the intended
    // pre-allocation, not the ambiguous length-vs-element footgun the rule warns on.
    "unicorn/no-new-array": "off"
  },
  "ignorePatterns": [
    "**/*.d.mts",
    "**/*.d.ts"
  ],
  "overrides": [
    { "files": ["src/**"], "env": { "browser": true } },
    { "files": ["scripts/**", "sim/**", "**/*.test.ts"], "env": { "node": true } },
    {
      // Tests spell the resource-grid stride out longhand (`0*R+0`, `1*R+0`) to
      // mirror the general `p*R+r` index math; those zero multiplications are
      // intentional documentation. Scoped to tests so a real `x * 0` in the
      // production sim/app still trips the rule.
      "files": ["**/*.test.ts"],
      "rules": { "oxc/erasing-op": "off" }
    }
  ]
}
