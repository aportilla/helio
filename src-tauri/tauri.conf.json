{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Helio",
  "version": "0.1.0",
  "identifier": "io.portill.helio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/helio/",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Helio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "backgroundColor": "#000008",
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
