{
  "name": "helio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:catalog": "node scripts/build-catalog.mjs",
    "predev": "npm run build:catalog",
    "prebuild": "npm run build:catalog",
    "pretypecheck": "npm run build:catalog",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:sim": "node --test 'sim/test/**/*.test.ts'",
    "typecheck:sim": "tsc -p sim/tsconfig.json",
    "test:facilities": "node --test 'src/facilities/test/**/*.test.ts'",
    "test:ships": "node --test 'src/ships/test/**/*.test.ts'",
    "test:factions": "node --test 'src/factions/test/**/*.test.ts'",
    "test:actions": "node --test 'src/actions/test/**/*.test.ts'",
    "test:data": "node --test 'src/data/test/**/*.test.ts'",
    "test:scene": "node --test 'src/scene/test/**/*.test.ts'",
    "test": "npm run test:sim && npm run test:facilities && npm run test:ships && npm run test:factions && npm run test:actions && npm run test:data && npm run test:scene",
    "typecheck:test": "tsc -p tsconfig.test.json",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check:boundaries": "node scripts/check-sim-boundary.mjs",
    "check": "node scripts/check.mjs",
    "audit:procgen": "node scripts/audit-procgen.mjs",
    "audit:variety": "node scripts/audit-variety.mjs",
    "check:disk-physics": "node scripts/check-disk-physics.mjs",
    "inspect:body": "node scripts/inspect-body.mjs",
    "inspect:csv": "node scripts/inspect-csv.mjs",
    "inspect:economy": "node scripts/inspect-economy.ts",
    "prescreenshot": "npm run build:catalog",
    "screenshot": "node scripts/screenshot.mjs"
  },
  "dependencies": {
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "@types/three": "0.184.0",
    "oxlint": "1.70.0",
    "puppeteer": "25.1.0",
    "typescript": "6.0.3",
    "vite": "8.0.10"
  },
  "engines": {
    "node": ">=23.6.0"
  }
}
